{
  "name": "awesome-nestjs-boilerplate",
  "version": "11.0.0",
  "description": "Awesome NestJS Boilerplate, Typescript, Postgres, TypeORM",
  "author": "Mina Gerges <c.mgerges@wc34.gov.sa>",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "build:prod": "nest build",
    "start:dev": "vite",
    "nest:start": "nest start ./src/main.ts",
    "nest:start:dev": "nest start --watch",
    "nest:start:debug": "nest start --debug --watch",
    "nest:watch": "nest start --watch ./src/main.ts",
    "start:prod": "node dist/main.js",
    "typeorm": "typeorm-ts-node-esm",
    "migration:generate": "pnpm run typeorm migration:generate -d ormconfig.ts",
    "migration:create": "pnpm run typeorm migration:create",
    "generate": "nest g -c awesome-nestjs-schematics --no-spec",
    "g": "pnpm run generate",
    "migration:run": "pnpm run typeorm migration:run -d ormconfig.ts",
    "migration:revert": "pnpm run typeorm migration:revert -d ormconfig.ts",
    "migration:show": "pnpm run typeorm migration:show -d ormconfig.ts",
    "schema:drop": "pnpm run typeorm schema:drop -d ormconfig.ts",
    "dev": "pnpm run nest:start",
    "dev:watch": "pnpm run nest:watch",
    "lint": "eslint .",
    "lint:changes": "biome check --staged",
    "lint:fix": "eslint --fix .",
    "test": "NODE_OPTIONS='--experimental-vm-modules' NODE_ENV=test jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' NODE_ENV=test jest --watch",
    "test:cov": "NODE_OPTIONS='--experimental-vm-modules' NODE_ENV=test jest --coverage",
    "test:debug": "NODE_ENV=test node --inspect-brk -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_ENV=test jest --config ./test/jest-e2e.json",
    "docs:dev": "vitepress dev docs --port 7070",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky",
    "release": "release-it"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "~0.5.1",
    "class-validator": "~0.14.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "libphonenumber-js": "^1.13.8",
    "lodash": "^4.17.21",
    "morgan": "^1.10.1",
    "nestjs-cls": "^6.0.1",
    "nestjs-i18n": "^10.5.1",
    "parse-duration": "^2.1.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "tslib": "^2.8.1",
    "typeorm": "0.3.20",
    "typeorm-transactional": "~0.5.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.33.0",
    "@nestjs/cli": "^11.0.10",
    "@nestjs/testing": "^11.1.6",
    "@stylistic/eslint-plugin": "^5.2.3",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.0",
    "@swc/plugin-transform-imports": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.17.1",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "awesome-nestjs-schematics": "^10.1.1",
    "cross-env": "^10.0.0",
    "esbuild": "^0.25.9",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-import-helpers": "^2.0.1",
    "eslint-plugin-n": "^17.21.3",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.4",
    "eslint-plugin-unicorn": "^60.0.0",
    "globals": "^16.3.0",
    "http-proxy": "^1.18.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "knip": "^6.0.3",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "taze": "^19.1.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1",
    "vite": "7.1.2",
    "vite-plugin-node": "^7.0.0",
    "vitepress": "^1.6.3"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "npx @biomejs/biome lint --write",
      "eslint --fix",
      "git add"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "verbatimModuleSyntax": false
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.+)\\.ts$": "$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
